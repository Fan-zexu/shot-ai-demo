# Both the Node API and Python Worker must resolve the same data root.
SHOT_AI_DATA_ROOT=/absolute/path/to/shot-ai-demo/data
SHOT_AI_DATABASE_PATH=/absolute/path/to/shot-ai-demo/data/shot-ai.sqlite
SHOT_AI_POSE_MODEL_PATH=/absolute/path/to/shot-ai-demo/models/pose_landmarker_full.task

SHOT_AI_WORKER_URL=http://127.0.0.1:8001
SHOT_AI_WORKER_TIMEOUT_MS=300000
SHOT_AI_API_HOST=127.0.0.1
SHOT_AI_API_PORT=3001
SHOT_AI_MAX_UPLOAD_BYTES=314572800
